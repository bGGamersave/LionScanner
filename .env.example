# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# COINGECKO_API_KEY: Key for CoinGecko Demo/Pro API (replaces CMC)
COINGECKO_API_KEY=

# NODE_ENV: MUST be "production" when deployed. Otherwise the server boots Vite
# dev middleware instead of serving the built dist/ bundle.
NODE_ENV=production

# ADMIN_API_KEY: Protects the admin endpoints (/api/admin/*: subscriber list and
# manual broadcast). If unset, the admin API is disabled entirely (fails closed).
# Send it as an "x-admin-key" header or "Authorization: Bearer <key>".
ADMIN_API_KEY=

# --- Email delivery -----------------------------------------------------------
# The server sends welcome + weekly reminder emails through the first configured
# provider in this order: Resend, then generic SMTP. Without one of these
# configured, sends fall back to an Ethereal preview inbox (no real delivery)
# and the API surfaces a delivery error to the client.

# Resend (preferred). Get a key at https://resend.com and verify the sender domain.
RESEND_API_KEY=

# Sender identity. Must be an address on a domain verified with your provider.
EMAIL_FROM="Lions Swarm AI <noreply@lionscanner.net>"

# Legacy SMTP fallback (SendGrid, SES, Gmail, etc.). Only used if RESEND_API_KEY is unset.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Payments (Solana Pay) + entitlements -------------------------------------
# On-chain USDC payments verified server-side. Real charging requires all three:

# The Solana wallet (base58 pubkey) that RECEIVES payments.
SOLANA_RECIPIENT_WALLET=

# RPC endpoint. The public mainnet endpoint is rate-limited and often blocks
# hosting providers — use a dedicated provider (Helius, QuickNode, Triton) in prod.
# For testing, use https://api.devnet.solana.com with a devnet USDC mint below.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# USDC SPL mint. Defaults to mainnet USDC. Override for devnet testing.
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Secret used to sign entitlement claim tokens (HMAC). Set a long random string.
# Falls back to ADMIN_API_KEY if unset. REQUIRED for secure entitlements in prod.
ENTITLEMENT_SECRET=

